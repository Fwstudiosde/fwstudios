# Auth
ADMIN_EMAIL=accounts@fwstudios.de
ADMIN_PASSWORD=change-me
SESSION_SECRET=generate-a-long-random-string

# Email (Resend) — optional, ohne Key wird nicht versendet
RESEND_API_KEY=
RESEND_FROM="FWStudios <hello@fwstudios.de>"
NOTIFY_EMAIL=accounts@fwstudios.de

# Public
NEXT_PUBLIC_SITE_URL=https://fwstudios.de
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=fwstudios.de
NEXT_PUBLIC_CAL_LINK=fwstudios/30min
NEXT_PUBLIC_CAL_ORIGIN=https://app.cal.eu

# Chatbot API keys — wenn gesetzt, überschreiben sie den im Admin-UI hinterlegten Key.
# Empfohlen für Render-Deploys, weil sie jeden Restart/Disk-Reset überleben.
ANTHROPIC_API_KEY=
CAL_API_KEY=
